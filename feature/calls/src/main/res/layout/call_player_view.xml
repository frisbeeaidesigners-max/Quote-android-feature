<?xml version="1.0" encoding="utf-8"?>
<!--
  PlayerView с surface_type=texture_view — нужно, чтобы Compose Modifier.clip (rounded corners)
  фактически обрезал видео. SurfaceView (default) рендерится в отдельный hardware overlay и
  не подчиняется Compose-clip'у, поэтому видео «вылезает» за округлый контейнер PiP. На
  TextureView рендер идёт в нормальный View canvas, и parent-клип работает корректно.

  use_controller=false — нет UI-контролов; resize_mode=zoom — fill+crop с сохранением aspect.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:resize_mode="zoom"
    app:surface_type="texture_view"
    app:use_controller="false" />
